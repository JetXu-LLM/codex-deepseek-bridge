{
  "name": "codex-deepseek-bridge",
  "version": "0.1.21",
  "description": "A tiny Responses-compatible local bridge that lets OpenAI Codex use DeepSeek LLM APIs.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Jet Xu",
  "homepage": "https://github.com/JetXu-LLM/codex-deepseek-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JetXu-LLM/codex-deepseek-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/JetXu-LLM/codex-deepseek-bridge/issues"
  },
  "keywords": [
    "codex",
    "deepseek",
    "deepseek-v4",
    "openai-codex",
    "codex-cli",
    "responses-api",
    "llm-proxy",
    "kv-cache",
    "usage-report",
    "agent",
    "coding-agent",
    "deepseek-api"
  ],
  "bin": {
    "codex-deepseek-bridge": "./bin/codex-deepseek-bridge.mjs"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "docs",
    "examples",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node scripts/check.mjs",
    "test": "node --test",
    "serve": "node ./bin/codex-deepseek-bridge.mjs serve",
    "doctor": "node ./bin/codex-deepseek-bridge.mjs doctor",
    "verify:codex-app": "node scripts/verify-codex-app-server.mjs",
    "bundle": "esbuild bin/codex-deepseek-bridge.mjs --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs",
    "build:binary": "node scripts/build-binary.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "postject": "1.0.0-alpha.6"
  },
  "engines": {
    "node": ">=18"
  }
}
